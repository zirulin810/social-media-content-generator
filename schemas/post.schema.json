{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/自動化輸出/schemas/post.schema.json",
  "title": "post.json",
  "description": "階段 4 產物：一則貼文的圖卡清單與各平台文案。一篇文章可能有 1–3 則，各自一個 out/<slug>/p<N>/post.json",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source",
    "post_index",
    "angle",
    "images",
    "posts"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "3.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "model": {
      "type": "string"
    },
    "human_edited": {
      "type": "boolean",
      "description": "人在編輯台改過文案。**設了之後，文案階段不再叫 LLM 重寫**——只會更新圖片清單。LLM 永遠不覆蓋人的編輯（v3.4，[[發布前預覽介面]]）。"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/image"
      }
    },
    "posts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/post"
      }
    },
    "post_index": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "description": "1-based，對應 highlights.posts 的順序"
    },
    "angle": {
      "type": "string",
      "minLength": 1,
      "description": "這則貼文的論點（封面標題）"
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": [
        "slug",
        "title",
        "url"
      ],
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1,
          "description": "選填。這是誰講的可以不知道（Google 課程、官方文件、白皮書常常沒有個人作者），但這是從哪來的不能不知道——少了作者只是資訊不全，少了 url 就是沒標來源的轉貼。"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "file": {
          "type": "string"
        }
      },
      "description": "出處。**author 選填，url 必填。**這是誰講的可以不知道（Google 課程、官方文件、白皮書常常沒有個人作者），但這是從哪來的不能不知道——少了作者只是資訊不全，少了 url 就是沒標來源的轉貼。"
    },
    "image": {
      "type": "object",
      "required": [
        "path",
        "role",
        "ratio"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^images/\\d{2}_(cover|point|steps|contrast|quote|outro)(_\\d+)?\\.(png|jpg)$",
          "description": "相對於 out/<slug>/ 的路徑"
        },
        "role": {
          "enum": [
            "cover",
            "point",
            "steps",
            "contrast",
            "quote",
            "outro"
          ]
        },
        "ratio": {
          "enum": [
            "1:1",
            "4:5"
          ]
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "card_index": {
          "type": "integer",
          "minimum": 1,
          "description": "1-based，對應 highlights.posts[].cards 的順序；封面與結尾不需要"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "role": {
                "enum": [
                  "point",
                  "steps",
                  "contrast",
                  "quote"
                ]
              }
            }
          },
          "then": {
            "required": [
              "card_index"
            ]
          }
        }
      ]
    },
    "post": {
      "type": "object",
      "required": [
        "platform",
        "caption",
        "image_paths",
        "attribution"
      ],
      "additionalProperties": false,
      "properties": {
        "platform": {
          "enum": [
            "instagram",
            "threads"
          ]
        },
        "caption": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2200,
          "description": "含出處標註的完整貼文文字，可直接複製貼上。Threads 需 ≤ 500 字（由模組自檢）"
        },
        "hashtags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^#\\S+$"
          }
        },
        "image_paths": {
          "type": "array",
          "minItems": 1,
          "description": "發布時的排圖順序",
          "items": {
            "type": "string",
            "pattern": "^images/"
          }
        },
        "attribution": {
          "type": "string",
          "minLength": 1,
          "description": "原文出處：標題 + 作者 + 連結。人宣告原創（original）時，這裡記「已宣告原創」"
        },
        "published_at": {
          "type": "string",
          "format": "date-time",
          "description": "人按下平台的「分享」後，回編輯台標「已發布」的時間（v3.6，[[一鍵發布到 IG 與 Threads]]）。程式永遠不自己按分享——這個欄位只記人的動作。"
        }
      }
    }
  }
}
