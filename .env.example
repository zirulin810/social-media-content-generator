# 複製成 .env（.env 不進版控）。
# 若 key 已經是系統環境變數，這個檔可以不建——程式會直接讀環境變數。

LLM_PROVIDER=gemini          # gemini 或 anthropic
GEMINI_API_KEY=              # 也認 GOOGLE_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ANTHROPIC_API_KEY=         # LLM_PROVIDER=anthropic 時才需要
# ANTHROPIC_MODEL=claude-sonnet-5

OUT_DIR=out
DEFAULT_RATIO=4:5
